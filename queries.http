### Kreiranje indeksa knjige
PUT /knjige
{
  "settings": {
    "analysis": {
      "analyzer": {
        "hrvatski_analyzer": {
          "tokenizer": "standard",
          "filter": [
            "lowercase",
            "asciifolding"
          ]
        }
      }
    }
  },
  "mappings": {
    "properties": {
      "naslov": {
        "type": "text",
        "analyzer": "hrvatski_analyzer",
        "fields": {
          "keyword": {
            "type": "keyword"
          }
        }
      },
      "autor": { "type": "keyword" },
      "zanr": { "type": "keyword" },
      "opis": {
        "type": "text",
        "analyzer": "hrvatski_analyzer"
      },
      "godina": { "type": "integer" },
      "cijena": { "type": "double" },
      "dostupno": { "type": "boolean" }
    }
  }
}

### Bulk unos knjiga
POST /knjige/_bulk
{ "index": { "_id": "1" } }
{ "naslov": "Na Drini ćuprija", "autor": "Ivo Andrić", "zanr": "roman", "opis": "Povijesni roman o mostu, ljudima i vremenu.", "godina": 1945, "cijena": 18.50, "dostupno": true }
{ "index": { "_id": "2" } }
{ "naslov": "Derviš i smrt", "autor": "Meša Selimović", "zanr": "roman", "opis": "Filozofski roman o vlasti, pravdi i ljudskoj sudbini.", "godina": 1966, "cijena": 22.00, "dostupno": true }
{ "index": { "_id": "3" } }
{ "naslov": "Tvrđava", "autor": "Meša Selimović", "zanr": "roman", "opis": "Roman o čovjeku, društvu i borbi za smisao.", "godina": 1970, "cijena": 20.00, "dostupno": false }
{ "index": { "_id": "4" } }
{ "naslov": "Travnička hronika", "autor": "Ivo Andrić", "zanr": "povijesni roman", "opis": "Priča o diplomatskom i društvenom životu u Travniku.", "godina": 1942, "cijena": 19.90, "dostupno": true }
{ "index": { "_id": "5" } }
{ "naslov": "Zločin i kazna", "autor": "Fjodor Dostojevski", "zanr": "roman", "opis": "Psihološki roman o krivnji, savjesti i iskupljenju.", "godina": 1866, "cijena": 24.50, "dostupno": true }

### Provjera broja dokumenata
GET /knjige/_count

### Match – naslov (cuprija)
GET /knjige/_search
{
  "query": {
    "match": {
      "naslov": "cuprija"
    }
  }
}

### Match – opis (pravda vlast sudbina)
GET /knjige/_search
{
  "query": {
    "match": {
      "opis": "pravda vlast sudbina"
    }
  }
}

### Match – opis (roman)
GET /knjige/_search
{
  "query": {
    "match": {
      "opis": "roman"
    }
  }
}

### Match – opis (pravda sudbina)
GET /knjige/_search
{
  "query": {
    "match": {
      "opis": "pravda sudbina"
    }
  }
}

### Term – autor (Ivo Andrić)
GET /knjige/_search
{
  "query": {
    "term": {
      "autor": "Ivo Andrić"
    }
  }
}

### Range – godina >= 1950
GET /knjige/_search
{
  "query": {
    "range": {
      "godina": {
        "gte": 1950
      }
    }
  }
}

### Bool – dostupno, cijena ≤ 22, opis roman
GET /knjige/_search
{
  "query": {
    "bool": {
      "must": [
        {
          "match": {
            "opis": "roman"
          }
        }
      ],
      "filter": [
        {
          "term": {
            "dostupno": true
          }
        },
        {
          "range": {
            "cijena": {
              "lte": 22
            }
          }
        }
      ]
    }
  }
}

### Analyze – test 1
POST /knjige/_analyze
{
  "analyzer": "hrvatski_analyzer",
  "text": "Brzi smeđi most preko rijeke!"
}

### Analyze – test 2
POST /knjige/_analyze
{
  "analyzer": "hrvatski_analyzer",
  "text": "Na Drini ćuprija"
}

### Agregacija – broj knjiga po autoru
GET /knjige/_search
{
  "size": 0,
  "aggs": {
    "knjige_po_autoru": {
      "terms": {
        "field": "autor"
      }
    }
  }
}

### Agregacija – prosječna cijena po žanru
GET /knjige/_search
{
  "size": 0,
  "aggs": {
    "po_zanru": {
      "terms": {
        "field": "zanr"
      },
      "aggs": {
        "prosjecna_cijena": {
          "avg": {
            "field": "cijena"
          }
        }
      }
    }
  }
}

### Agregacija – najskuplja knjiga po žanru
GET /knjige/_search
{
  "size": 0,
  "aggs": {
    "po_zanru": {
      "terms": {
        "field": "zanr"
      },
      "aggs": {
        "najveca_cijena": {
          "max": {
            "field": "cijena"
          }
        }
      }
    }
  }
}

### Agregacija – dostupnost
GET /knjige/_search
{
  "size": 0,
  "aggs": {
    "dostupnost": {
      "terms": {
        "field": "dostupno"
      }
    }
  }
}

### Kreiranje indeksa filmovi
PUT /filmovi
{
  "settings": {
    "analysis": {
      "analyzer": {
        "hrvatski_analyzer": {
          "tokenizer": "standard",
          "filter": ["lowercase", "asciifolding"]
        }
      }
    }
  },
  "mappings": {
    "properties": {
      "naslov": { "type": "text" },
      "redatelj": { "type": "keyword" },
      "zanr": { "type": "keyword" },
      "opis": { "type": "text" },
      "godina": { "type": "integer" },
      "ocjena": { "type": "double" },
      "dostupno": { "type": "boolean" }
    }
  }
}

