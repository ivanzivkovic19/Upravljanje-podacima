### Match – filmovi
GET /filmovi/_search
{
  "query": {
    "match": {
      "opis": "borba"
    }
  }
}

### Term – redatelj
GET /filmovi/_search
{
  "query": {
    "term": {
      "redatelj": "Milos Avramović"
    }
  }
}

### Range – ocjena > 8
GET /filmovi/_search
{
  "query": {
    "range": {
      "ocjena": {
        "gt": 8
      }
    }
  }
}

### Bool – filmovi
GET /filmovi/_search
{
  "query": {
    "bool": {
      "must": [
        {
          "match": {
            "opis": "film"
          }
        }
      ],
      "filter": [
        {
          "term": {
            "dostupno": true
          }
        },
        {
          "range": {
            "ocjena": {
              "gte": 7
            }
          }
        }
      ]
    }
  }
}

### Agregacija – filmovi
GET /filmovi/_search
{
  "size": 0,
  "aggs": {
    "po_zanru": {
      "terms": {
        "field": "zanr"
      },
      "aggs": {
        "prosjecna_ocjena": {
          "avg": {
            "field": "ocjena"
          }
        }
      }
    }
  }
}